# Local development — copy to .env and fill real values.
# NEVER commit .env. Generate secrets: openssl rand -base64 32

DATABASE_URL="file:./dev.db"
API_PORT=3001
WEB_ORIGIN="http://localhost:3000"
SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Critical: replace before any shared/staging deploy
JWT_SECRET="REPLACE_WITH_openssl_rand_base64_32"

# When Docker Postgres is available:
# DATABASE_URL="postgresql://nhabar:REPLACE_ME@localhost:5432/nhabar?schema=public"
