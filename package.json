{
  "name": "nhabar-project",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @nhabar/web",
    "dev:api": "npm run start:dev -w @nhabar/api",
    "lint": "npm run lint -w @nhabar/web && npm run lint -w @nhabar/api",
    "test": "npm run test -w @nhabar/api && npm run test -w @nhabar/web",
